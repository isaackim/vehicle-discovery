# ─── Anthropic ────────────────────────────────────────────────────────────────
# Claude API key — used for NLP lead extraction and VIO scoring
ANTHROPIC_API_KEY=sk-ant-...

# ─── Inngest ──────────────────────────────────────────────────────────────────
# Signing key and event key from the Inngest dashboard
INNGEST_SIGNING_KEY=signkey-prod-...
INNGEST_EVENT_KEY=...

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Project URL and service role key (server-side only — never expose to the browser)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Public anon key (safe for browser/client components)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ─── Reddit (PRAW) ────────────────────────────────────────────────────────────
# Create an app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=...
REDDIT_CLIENT_SECRET=...
REDDIT_USER_AGENT=dyno-lead-agent/0.1 by u/<your-username>
REDDIT_USERNAME=...
REDDIT_PASSWORD=...

# ─── Apify ────────────────────────────────────────────────────────────────────
# Used by the social media agent for Instagram / Facebook Marketplace scraping
APIFY_API_TOKEN=apify_api_...

# ─── Tavily ───────────────────────────────────────────────────────────────────
# Used by the search agent for broad web queries
TAVILY_API_KEY=tvly-...

# ─── Next.js ──────────────────────────────────────────────────────────────────
# Base URL for the app (used for Inngest webhook registration)
NEXTAUTH_URL=http://localhost:3000
